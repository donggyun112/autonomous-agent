AGENT_LLM=anthropic
# AGENT_MODEL=gpt-5.4-mini
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-6
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-5.4-mini
OPENAI_AUXILIARY_MODEL=gpt-5.4-nano
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
SUPER_MEMORY_DATA_DIR=./data/memory

# Brave Search API — for web_search tool.
# Free tier available at https://brave.com/search/api/
# If unset, web_search returns an error but other tools still work.
BRAVE_API_KEY=

# ─── Discord (future surface) ──────────────────────────────────────────
# The file-based data/conversation/ inbox/outbox is the canonical transport
# for now. When Discord is wired up later, it will be a mirror on top of
# the file layer — the agent's tool interface (ask_user/check_inbox/
# write_letter) will not change.
#
# For now only the bot token is needed as a placeholder. The rest (guild,
# user ID, channel) will be discovered by the Discord adapter at startup.
DISCORD_BOT_TOKEN=
