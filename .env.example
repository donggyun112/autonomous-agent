# ============================================================================
# autonomous-agent — Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values.
# Only AGENT_LLM + its corresponding config section is required.
# ============================================================================

# ─── LLM Provider ────────────────────────────────────────────────────────
# Which LLM to use. Pick ONE: local, anthropic, or openai.
AGENT_LLM=local

# ─── Option 1: Local Model (MLX / llama.cpp / vLLM) ─────────────────────
# Recommended for Apple Silicon. Start your server first:
#   mlx_lm.server --model mlx-community/Qwen3.6-35B-A3B-4bit --port 8080 \
#     --chat-template-args '{"enable_thinking":true}'
LOCAL_LLM_URL=http://host.docker.internal:8080
LOCAL_LLM_MODEL=mlx-community/Qwen3.6-35B-A3B-4bit
LOCAL_LLM_CONTEXT=65000

# ─── Option 2: Anthropic ─────────────────────────────────────────────────
# AGENT_LLM=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ─── Option 3: OpenAI ───────────────────────────────────────────────────
# AGENT_LLM=openai
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4.1-mini

# ─── Agent Time ──────────────────────────────────────────────────────────
# How fast the agent's subjective clock runs relative to wall-clock.
# 1 = real-time, 20 = 1 minute wall = 20 minutes agent-time.
TIME_SCALE=20

# ─── Embedding (for memory recall) ──────────────────────────────────────
# "local" = uses @xenova/transformers (free, needs install)
# "openai" = uses OpenAI embedding API (needs OPENAI_API_KEY)
# If neither works, falls back to hash-based (no semantic recall).
EMBEDDING_BACKEND=local

# ─── Optional: Web Search ───────────────────────────────────────────────
# Free tier: https://brave.com/search/api/
# BRAVE_API_KEY=

# ─── Optional: Discord Integration ──────────────────────────────────────
# DISCORD_BOT_TOKEN=

# ─── Optional: Git (for agent to push code) ─────────────────────────────
# GIT_TOKEN=ghp_...
# GIT_USER=your-github-username

# ─── Optional: Oracle (second opinion from a different model) ───────────
# ORACLE_MODEL=gpt-4.1-mini
